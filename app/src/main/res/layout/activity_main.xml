<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FA"
    android:padding="18dp">

    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:text="💰"
        android:textSize="30sp"
        android:gravity="center"
        android:background="#E0E7FF"
        android:layout_gravity="center"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Control de Gastos"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:gravity="center" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Administra tus finanzas personales"
        android:textSize="13sp"
        android:textColor="#334155"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="10dp"
        android:elevation="4dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👋 Bienvenido"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#0F172A" />

        <TextView
            android:id="@+id/txtBienvenida"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bienvenido"
            android:textSize="13sp"
            android:textColor="#334155"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="10dp"
        android:elevation="4dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nuevo gasto"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/edtNombreGasto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre del gasto"
            android:textColor="#0F172A"
            android:textColorHint="#475569"
            android:backgroundTint="#6366F1" />

        <EditText
            android:id="@+id/edtMonto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Monto"
            android:inputType="numberDecimal"
            android:textColor="#0F172A"
            android:textColorHint="#475569"
            android:backgroundTint="#6366F1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Categoría"
            android:textColor="#0F172A"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/txtCategoriaSeleccionada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏷️ Seleccionar categoría"
            android:textColor="#0F172A"
            android:textSize="15sp"
            android:padding="12dp"
            android:background="#EEF2FF"
            android:clickable="true"
            android:focusable="true" />

        <EditText
            android:id="@+id/edtFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Seleccionar fecha"
            android:focusable="false"
            android:clickable="true"
            android:inputType="none"
            android:textColor="#0F172A"
            android:textColorHint="#475569"
            android:backgroundTint="#6366F1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Guardar"
                android:textColor="@android:color/white"
                android:backgroundTint="#4F46E5"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnCerrarSesion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cerrar sesión"
                android:textColor="@android:color/white"
                android:backgroundTint="#D32F2F"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/txtTotalMensual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total mensual: $0.00"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:background="#E0E7FF"
        android:padding="10dp"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/txtHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Historial de gastos"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:layout_marginBottom="4dp" />

    <ListView
        android:id="@+id/listaGastos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:divider="#CBD5E1"
        android:dividerHeight="1dp"
        android:padding="4dp"
        android:scrollbars="vertical"
        android:fadeScrollbars="false" />

</LinearLayout>